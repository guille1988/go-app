# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH_APP_NAME=auth
AUTH_APP_ENV=local
AUTH_APP_HOST=0.0.0.0
AUTH_APP_PORT=8080

AUTH_DB_DRIVER=mysql
AUTH_DB_HOST=mysql_auth
AUTH_DB_PORT=3306
AUTH_DB_DATABASE=auth
AUTH_DB_USERNAME=auth
AUTH_DB_PASSWORD=auth
AUTH_DB_MAX_IDLE_CONNECTIONS=10
AUTH_DB_MAX_OPEN_CONNECTIONS=100

AUTH_LOG_DRIVER=stdout
AUTH_LOG_PATH=logs/auth.log
AUTH_LOG_LEVEL=debug

AUTH_REDIS_HOST=redis
AUTH_REDIS_PORT=6379
AUTH_REDIS_PASSWORD=auth
AUTH_REDIS_DATABASE=0

AUTH_JWT_SECRET=secret
AUTH_ACCESS_TOKEN_EXPIRE=15
AUTH_REFRESH_TOKEN_EXPIRE=10080
AUTH_EMAIL_VERIFICATION_EXPIRE=60
AUTH_FRONTEND_URL=

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_APP_NAME=email
EMAIL_APP_ENV=local

EMAIL_DB_DRIVER=mysql
EMAIL_DB_HOST=mysql_email
EMAIL_DB_PORT=3306
EMAIL_DB_DATABASE=email
EMAIL_DB_USERNAME=email
EMAIL_DB_PASSWORD=email
EMAIL_DB_MAX_IDLE_CONNECTIONS=10
EMAIL_DB_MAX_OPEN_CONNECTIONS=100

EMAIL_LOG_DRIVER=stdout
EMAIL_LOG_PATH=logs/email.log
EMAIL_LOG_LEVEL=debug

EMAIL_MAIL_HOST=mailpit
EMAIL_MAIL_PORT=1025
EMAIL_MAIL_USER=
EMAIL_MAIL_PASSWORD=

EMAIL_KAFKA_REBALANCE_TIMEOUT_MS=600000
EMAIL_KAFKA_WORKER_POOL_SIZE=20

# ── Broadcasting ──────────────────────────────────────────────────────────────
BROADCASTING_APP_NAME=broadcasting
BROADCASTING_APP_ENV=local
BROADCASTING_APP_PORT=8081

BROADCASTING_LOG_DRIVER=stdout
BROADCASTING_LOG_PATH=logs/broadcasting.log
BROADCASTING_LOG_LEVEL=debug

BROADCASTING_KAFKA_REBALANCE_TIMEOUT_MS=600000
BROADCASTING_KAFKA_WORKER_POOL_SIZE=20

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_PORT=9092
KAFKA_CLUSTER_ID=q1Sh8sEGKs2p10e6oNJklw
KAFKA_NODE_ID=1
KAFKA_NUM_PARTITIONS=10
KAFKA_LOG_RETENTION_MS=120000

# ── Shared ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092

MYSQL_ROOT_PASSWORD=password

TRAEFIK_DASHBOARD_PORT=8090
